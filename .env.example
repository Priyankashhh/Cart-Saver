# ──────────────────────────────────────────────
# CartSaver — Environment Variables
# Copy this to .env and fill in your real values.
# ──────────────────────────────────────────────

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cartsaver
DB_USER=postgres
DB_PASSWORD=postgres

# NVIDIA NIM API
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=cartsaver@example.com

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+15005550006
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Scheduler
PIPELINE_SCHEDULE_HOUR=9
PIPELINE_SCHEDULE_MINUTE=0
